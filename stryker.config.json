{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Deny-list: mutate all src/ except DOM-entangled adapters covered by Playwright (bootstrap, render.ts TemplateResult builders, input/**). New pure files are picked up automatically.",
  "packageManager": "npm",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/**/*.d.ts",
    "!src/adapters/bootstrap.ts",
    "!src/adapters/render.ts",
    "!src/adapters/announce.ts",
    "!src/adapters/input/pointer.ts",
    "!src/adapters/input/keyboard.ts"
  ],
  "coverageAnalysis": "perTest",
  "reporters": ["progress", "clear-text", "html"],
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 80
  },
  "concurrency": 4,
  "timeoutMS": 10000,
  "cleanTempDir": true
}
